{
  "name": "kkn-literasi-2026",
  "version": "1.0.0",
  "description": "Library catalog portal (Express + Prisma + React)",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev",
    "build": "npm --prefix client run build",
    "build:client": "npm --prefix client run build",
    "seed:server": "npm --prefix server run seed",
    "smoke:server": "npm --prefix server run smoke",
    "prisma:generate:server": "npm --prefix server run prisma:generate",
    "prisma:push:server": "npm --prefix server run prisma:push",
    "prisma:studio:server": "npm --prefix server run prisma:studio",
    "prisma:migrate:dev:server": "npm --prefix server run prisma:migrate:dev",
    "prisma:migrate:deploy:server": "npm --prefix server run prisma:migrate:deploy",
    "test": "npm --prefix client run build && npm --prefix server run smoke"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^7.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
